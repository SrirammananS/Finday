<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.LAKSH.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/app_text_secondary</item>
        <item name="cursorColor">@color/primary</item>
    </style>

    <style name="Widget.LAKSH.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.LAKSH.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
    </style>
</resources>
